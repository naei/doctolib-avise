{
  "manifest_version": 3,
  "name": "Doctolib Avisé",
  "version": "1.0.0",
  "description": "Affiche les notes Google Maps des praticiens sur Doctolib",
  "permissions": ["storage"],
  "host_permissions": [
    "https://maps.googleapis.com/*",
    "https://www.doctolib.fr/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.doctolib.fr/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Doctolib Avisé",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
